rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the owner can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Per-user notifications subcollection
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Service requests — any authenticated user can submit; anyone authenticated can read (admin needs this)
    match /towing_requests/{docId} {
      allow read, write: if request.auth != null;
    }
    match /mechanic_requests/{docId} {
      allow read, write: if request.auth != null;
    }
    match /diagnostic_requests/{docId} {
      allow read, write: if request.auth != null;
    }
    match /car_wash_requests/{docId} {
      allow read, write: if request.auth != null;
    }
    match /car_rental_requests/{docId} {
      allow read, write: if request.auth != null;
    }
    match /parts_orders/{docId} {
      allow read, write: if request.auth != null;
    }

    // Spare parts product catalogue — authenticated read, admin write
    match /product/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Shopping cart and orders
    match /cart/{docId} {
      allow read, write: if request.auth != null;
    }
    match /orders/{docId} {
      allow read, write: if request.auth != null;
    }
    match /orders_history/{docId} {
      allow read, write: if request.auth != null;
    }

    // Global notifications collection
    match /notifications/{docId} {
      allow read, write: if request.auth != null;
    }

    // Homepage banner — public read so unauthenticated splash can load it
    match /homepage/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Car brands catalogue — public read so users can browse before login
    match /car_brands/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // History collections used by admin dashboard
    match /car_wash_requests_history/{docId} {
      allow read, write: if request.auth != null;
    }
    match /mechanic_requests_history/{docId} {
      allow read, write: if request.auth != null;
    }
    match /diagnostic_requests_history/{docId} {
      allow read, write: if request.auth != null;
    }

    // Admins collection — authenticated read for login verification
    match /admins/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
